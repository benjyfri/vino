{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "Bash(*)"
    ],
    "deny": [
      "Bash(git*)",
      "Bash(rm -r*)",
      "Bash(rm -R*)",
      "Bash(rm -*r*)",
      "Bash(rmdir*)"
    ]
  }
}